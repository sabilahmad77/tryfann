# Frontend env (Vite). Copy to .env.local for local dev (gitignored).
# All VITE_* vars are BUILD-TIME and PUBLIC — they are embedded in the shipped
# bundle. Never put secrets here (no API keys, no DB creds).

# --- API base URL ---
# Local dev: leave as /api — the Vite dev server proxies /api -> the local
# Django backend (see vite.config.mjs), so calls are same-origin.
# Production (Vercel): point at the standalone TryFANN API, including /api:
#   VITE_API_BASE_URL=https://api.tryfann.com/api
VITE_API_BASE_URL=/api

# --- Google Sign-In (public client id) ---
# The Google OAuth **Web** Client ID. MUST match the backend's
# GOOGLE_OAUTH_CLIENT_ID. The Google Cloud console must list the site origins
# (https://www.tryfann.com, https://tryfann.com) under Authorized JS origins.
# Empty -> the Google button does not render.
VITE_GOOGLE_CLIENT_ID=

# --- Analytics (public GA4 measurement id) ---
# GA4 id (e.g. G-XXXXXXXXXX). Optional. Analytics only load AFTER the user
# grants consent; leave blank to disable the GA mirror entirely (the app's own
# server-side funnel still records events).
VITE_GA_MEASUREMENT_ID=
